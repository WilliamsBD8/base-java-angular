erDiagram
    USERS {
        bigint id PK
        varchar name
        varchar email UK
        varchar password
        state_user state
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    ROLES {
        bigint id PK
        varchar name UK
        varchar description
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    USER_ROLES {
        bigint user_id PK_FK
        bigint role_id PK_FK
    }

    CATEGORIES {
        bigint id PK
        varchar name UK
        text description
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    CONVOCATIONS {
        bigint id PK
        bigint user_id FK
        varchar name
        text description
        timestamp initial_date
        timestamp final_date
