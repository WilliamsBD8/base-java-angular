        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    CONVOCATION_CATEGORIES {
        bigint convocation_id PK_FK
        bigint category_id PK_FK
    }

    PETITIONS {
        bigint id PK
        bigint convocation_id FK
        bigint user_id FK
        petition_state state
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

