# Base de datos (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=convocatorias
DB_USER=postgres
DB_PASSWORD=postgres

# Puertos de los servicios Docker
BACKEND_PORT=8080
FRONTEND_PORT=4200

# JWT (mínimo 256 bits / 32 caracteres para HS256)
JWT_SECRET=cambia_este_secreto_por_uno_seguro_de_al_menos_32_caracteres
JWT_EXPIRATION=86400000

# Perfil Spring (dev | prod)
SPRING_PROFILES_ACTIVE=dev
