# Base de datos (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=convocatorias
DB_USER=postgres
DB_PASSWORD=postgres

# Puertos de los servicios Docker (desarrollo local)
BACKEND_PORT=8080
FRONTEND_PORT=4200

# JWT (mínimo 256 bits / 32 caracteres para HS256)
JWT_SECRET=cambia_este_secreto_por_uno_seguro_de_al_menos_32_caracteres
JWT_EXPIRATION=86400000

# Perfil Spring (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# CORS — orígenes permitidos separados por coma
# Desarrollo local:
CORS_ALLOWED_ORIGINS=http://localhost:4200
# Railway (ejemplo, usar la URL pública del frontend):
# CORS_ALLOWED_ORIGINS=https://tu-frontend.up.railway.app

# Railway — servicio Frontend (variable de build para inyectar la URL del API)
# API_URL=https://tu-backend.up.railway.app/api/v1

# Railway — servicio Backend (referencias al plugin PostgreSQL)
# DB_HOST=${{Postgres.PGHOST}}
# DB_PORT=${{Postgres.PGPORT}}
# DB_NAME=${{Postgres.PGDATABASE}}
# DB_USER=${{Postgres.PGUSER}}
# DB_PASSWORD=${{Postgres.PGPASSWORD}}
# SPRING_PROFILES_ACTIVE=prod
